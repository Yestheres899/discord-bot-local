# Token do seu bot Discord (obrigatório)
DISCORD_TOKEN=SEU_TOKEN_AQUI

# --- Escolha o backend de IA ---

# OPÇÃO 1: Groq (grátis, para hospedar no Render/nuvem)
# Crie em: https://console.groq.com → API Keys
GROQ_API_KEY=

# OPÇÃO 2: Ollama (local, só funciona rodando na sua máquina)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Se GROQ_API_KEY estiver definido, usa Groq. Senão, usa Ollama.

# --- Configurações opcionais ---
BOT_NAME=LocalIA
SPONTANEOUS_CHANCE=30
GROQ_MODEL=llama-3.3-70b-versatile
# BOT_PERSONA=coloque aqui uma personalidade customizada
